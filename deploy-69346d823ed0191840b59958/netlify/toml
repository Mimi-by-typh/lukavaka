[build]
  publish = "public"
  functions = "netlify/functions"

[build.environment]
  NODE_VERSION = "18"

[[redirects]]
  from = "/api/*"
  to = "/.netlify/functions/:splat"
  status = 200

[context.production]
  command = "echo 'No build command needed'"

[context.deploy-preview]
  command = "echo 'No build command needed'"

[context.branch-deploy]
  command = "echo 'No build command needed'"

[dev]
  command = "echo 'Starting development server...'"
  port = 3000
  publish = "public"
  functions = "netlify/functions"
